{
    "name": "Balloon-Receiver - ESP-IDF Development",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "workspaceFolder": "/workspaces/Balloon-Receiver",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "espressif.esp-idf-extension"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "python.defaultInterpreterPath": "/usr/bin/python3",
                "C_Cpp.default.compilerPath": "/usr/bin/gcc",
                "idf.espIdfPath": "/opt/esp-idf",
                "idf.toolsPath": "/opt/esp-idf-tools"
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/devcontainers/features/sshd:1": {
            "version": "latest"
        }
    },
    "runArgs": [
        "--name", "balloon-receiver",
        "--privileged",
        "-v", "/dev:/dev"
    ],
    "appPort": ["2634:2222"],
    "postCreateCommand": "git config --global credential.helper store && git config --global core.sshCommand 'ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null' && (git clone https://github.com/SensorsIot/claude.git ~/.claude 2>/dev/null || (cd ~/.claude && git pull)) && mkdir -p ~/.claude-data/projects && ln -sf ~/.claude-data/.credentials.json ~/.claude/.credentials.json && ln -sf ~/.claude-data/history.jsonl ~/.claude/history.jsonl && rm -rf ~/.claude/projects && ln -sf ~/.claude-data/projects ~/.claude/projects && ln -sf ~/.claude-data/.claude.json ~/.claude.json && npm install -g @anthropic-ai/claude-code && echo 'alias superclaude=\"claude --dangerously-skip-permissions\"' >> ~/.bashrc && mkdir -p ~/.githooks && cp ~/.claude/githooks/pre-push ~/.githooks/pre-push && chmod +x ~/.githooks/pre-push && git config --global core.hooksPath ~/.githooks && . /opt/esp-idf/export.sh",
    "remoteUser": "dev",
    "containerEnv": {
        "IDF_PATH": "/opt/esp-idf",
        "IDF_TOOLS_PATH": "/opt/esp-idf-tools",
        "INFLUXDB_TOKEN": "${localEnv:INFLUXDB_TOKEN}",
        "INFLUXDB_URL": "${localEnv:INFLUXDB_URL}",
        "INFLUXDB_ORG": "${localEnv:INFLUXDB_ORG}",
        "HA_TOKEN": "${localEnv:HA_TOKEN}",
        "HA_TOKEN_NODERED": "${localEnv:HA_TOKEN_NODERED}",
        "HA_URL": "${localEnv:HA_URL}",
        "GRAFANA_URL": "${localEnv:GRAFANA_URL}",
        "GRAFANA_USER": "${localEnv:GRAFANA_USER}",
        "GRAFANA_PASSWORD": "${localEnv:GRAFANA_PASSWORD}",
        "TELEGRAM_BOT_TOKEN": "${localEnv:TELEGRAM_BOT_TOKEN}"
    },
    "mounts": [
        "source=${localEnv:HOME}/.ssh/authorized_keys,target=/home/dev/.ssh/authorized_keys,type=bind,readonly",
        "source=${localEnv:HOME}/.ssh/id_ed25519,target=/home/dev/.ssh/id_ed25519,type=bind,readonly",
        "source=${localEnv:HOME}/.git-credentials,target=/home/dev/.git-credentials,type=bind,readonly",
        "source=${localWorkspaceFolder}/.claude-data,target=/home/dev/.claude-data,type=bind",
        "source=${localEnv:HOME}/.claude-containers/Balloon-Receiver,target=/home/dev/.claude,type=bind"
    ]
}
